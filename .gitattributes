# Force LF line endings on Cloudflare/Linux builds for all text files
* text=auto eol=lf

# Explicitly set LF for source code
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.md   text eol=lf
*.xml  text eol=lf
*.txt  text eol=lf
*.toml text eol=lf

# Binary files — do not convert
*.png  binary
*.jpg  binary
*.ico  binary
*.woff binary
*.woff2 binary
